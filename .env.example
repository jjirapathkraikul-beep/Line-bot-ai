# LINE Messaging API — จาก LINE Developers Console
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# OpenAI API — จาก platform.openai.com
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Sheet FAQ — Public CSV Export URL
# วิธีได้ URL: Google Sheet → File → Share → Publish to web → CSV → Copy link
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# Google Sheet CRM — Google Apps Script Web App URL
# วิธีได้ URL: สร้าง Apps Script → Deploy as Web App → Copy URL
LEAD_SHEET_CSV_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
